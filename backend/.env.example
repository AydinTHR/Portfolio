# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017
DB_NAME=portfolio

# ---- Admin auth (single admin) ----
ADMIN_EMAIL=you@example.com
# Generate the hash with:  python scripts/hash_password.py
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=12

# ---- Environment / cookies ----
# "production" marks the auth cookie Secure (HTTPS-only)
ENVIRONMENT=development
# Optional: restrict the auth cookie to a domain (leave blank for host-only)
COOKIE_DOMAIN=
# Cookie SameSite policy: lax | strict | none. Use "none" only when the frontend
# and API are on different sites in production (requires HTTPS / Secure cookies).
COOKIE_SAMESITE=lax

# ---- CORS (comma-separated origins allowed to call the API) ----
FRONTEND_ORIGIN=http://localhost:5173

# ---- Resend email (contact form) ----
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
CONTACT_TO_EMAIL=you@example.com

# ---- Analytics ----
ANALYTICS_SALT=change-me-to-a-random-string
